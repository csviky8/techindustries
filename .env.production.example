# ── App ──────────────────────────────────────
APP_NAME=SafeTek
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://safetek-api.onrender.com

# ── Database (Neon PostgreSQL) ────────────────
DB_CONNECTION=pgsql
DB_HOST=ep-shiny-scene-av4umgpo.c-11.us-east-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=
DB_SSLMODE=require
DB_PGSQL_OPTIONS=endpoint=ep-shiny-scene-av4umgpo

# ── Sanctum ──────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=safetek.vercel.app
SESSION_DOMAIN=.vercel.app

# ── CORS ─────────────────────────────────────
FRONTEND_URL=https://safetek.vercel.app
CORS_ALLOWED_ORIGINS=https://safetek.vercel.app

# ── Cache / Session ───────────────────────────
CACHE_STORE=database
SESSION_DRIVER=cookie
QUEUE_CONNECTION=database

# ── Frontend (Vite / Vercel) ──────────────────
VITE_API_URL=https://safetek-api.onrender.com/api/v1
