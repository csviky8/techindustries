# ── App ──────────────────────────────────────
APP_NAME=SafeTek
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-laravel-api.railway.app

# ── Database (MySQL on Railway/PlanetScale) ──
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=safetek
DB_USERNAME=root
DB_PASSWORD=

# ── Sanctum ──────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=your-vercel-app.vercel.app
SESSION_DOMAIN=.vercel.app

# ── CORS ─────────────────────────────────────
FRONTEND_URL=https://your-vercel-app.vercel.app

# ── Cache / Session ───────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# ── Frontend (Vite / Vercel) ──────────────────
VITE_API_URL=https://your-laravel-api.railway.app/api/v1
